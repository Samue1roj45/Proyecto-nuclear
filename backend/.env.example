# Copia estas variables al iniciar el backend (PowerShell):
# $env:MAIL_HOST="smtp.gmail.com"
# etc.

# ── Correo SMTP (códigos de recuperación) ──
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=tu_correo@gmail.com
MAIL_PASSWORD=contraseña_de_aplicacion_gmail
MAIL_FROM=tu_correo@gmail.com

# ── Google OAuth ──
# https://console.cloud.google.com/apis/credentials
# Tipo: Aplicación web | Orígenes: http://localhost:4200 | No requiere redirect URI para popup postmessage
GOOGLE_CLIENT_ID=tu_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=tu_google_client_secret

# ── Facebook OAuth ──
# https://developers.facebook.com/apps
# Facebook Login activo | Dominios: localhost | URL sitio: http://localhost:4200
FACEBOOK_APP_ID=tu_facebook_app_id
FACEBOOK_APP_SECRET=tu_facebook_app_secret
